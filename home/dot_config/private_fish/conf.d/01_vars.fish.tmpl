set -gx CARGO_HOME "$HOME/.cargo"
set -gx DELTA_PAGER "less -FRX"
set -gx PNPM_HOME "$HOME/.local/share/pnpm"
set -gx XDG_CACHE_HOME "$HOME/.cache"
set -gx XDG_CONFIG_HOME "$HOME/.config"
set -gx XDG_DATA_HOME "$HOME/.local/share"
set -gx XDG_STATE_HOME "$HOME/.local/state"
{{ if .enable.mise_corepack }}set -gx MISE_NODE_COREPACK "1"{{ end }}
{{ if .enable.aws_vault }}set -gx AWS_VAULT_PROMPT "ykman"{{ end }}

set -gx GOPATH "$HOME/src/go"
set -gx MISE_GO_SET_GOBIN false
set -gx MISE_GO_SET_GOROOT false

# chezmoi configured features {{ $enableMap := .enable }}
{{ range keys $enableMap | sortAlpha -}}
set -gx LD_CHEZMOI_FEATURE_{{ upper . }} {{ index $enableMap . | quote }}
{{ end }}

set -gx EDITOR "vim"
set -gx VISUAL "code --wait"

# keep failed commands in history just a little longer
set -g sponge_delay 10
# keep ctrl-c'd commands in history, plus 141 = SIGPIPE
set sponge_successful_exit_codes 0 127 130 141

# custom sponge filter allowing for specific failures
set -ge sponge_filters
set -g sponge_filters sponge_custom_filter
