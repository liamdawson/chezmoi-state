{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "\"$HOME\"/util/misc/claude/hooks/pre-tool-use.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "python3 \"$HOME/.claude/hooks/tirith-check.py\"",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  },
  "mcpServers": {
    "tirith": {
      "args": [
        "mcp-server"
      ],
      "command": "tirith"
    }
  },
  "theme": "auto"
}